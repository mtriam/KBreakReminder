<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0 http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
    <kcfgfile name=""/>
    <group name="">
        <entry name="intervalMinutes" type="Int">
            <label>Short break frequency (minutes)</label>
            <default>15</default>
            <min>3</min>
            <max>120</max>
        </entry>
        <entry name="longEveryNCycles" type="Int">
            <label>Long break every N short cycles</label>
            <default>4</default>
            <min>2</min>
            <max>12</max>
        </entry>
        <entry name="shortTotalSeconds" type="Int">
            <label>Short break duration (seconds)</label>
            <default>15</default>
            <min>5</min>
            <max>120</max>
        </entry>
        <entry name="shortFlashIntervalMs" type="Int">
            <label>Flash interval during short break (ms)</label>
            <default>500</default>
            <min>200</min>
            <max>2000</max>
        </entry>
        <entry name="longTotalSeconds" type="Int">
            <label>Long break duration (seconds)</label>
            <default>60</default>
            <min>20</min>
            <max>300</max>
        </entry>
        <entry name="longFlashIntervalMs" type="Int">
            <label>Flash interval during long break (ms)</label>
            <default>1000</default>
            <min>400</min>
            <max>3000</max>
        </entry>
    </group>
</kcfg>
